---
import BaseLayout from "../layouts/BaseLayout.astro";
import publications from "../data/publications.json";

type Publication = {
  id: string;
  title: string;
  year: number | null;
  date: string | null;
  venue: string;
  authors: string[];
  link: string;
  abstract: string | null;
};

const SELF = "Danilo Danese";

// Group by year, newest first. Years are already sorted by the fetch script.
const byYear = new Map<number | "Other", Publication[]>();
for (const pub of publications as Publication[]) {
  const key = pub.year ?? "Other";
  if (!byYear.has(key)) byYear.set(key, []);
  byYear.get(key)!.push(pub);
}
const groups = Array.from(byYear.entries());
---

<BaseLayout title="Publications" sideBarActiveItemID="publications">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Publications</div>
  </div>

  {groups.map(([year, items]) => (
    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-3">{year}</h2>
      <ul class="space-y-3">
        {items.map((pub) => (
          <li class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out p-4 border border-base-200">
            <a href={pub.link} target="_blank" rel="noopener" class="block">
              <h3 class="text-lg font-bold leading-snug">
                {pub.title}
                {pub.venue && <span class="badge badge-secondary ml-2 align-middle">{pub.venue}</span>}
              </h3>
              <p class="py-1 text-sm">
                {pub.authors.map((name, i) => (
                  <>
                    {i > 0 && ", "}
                    {name === SELF ? <strong>{name}</strong> : name}
                  </>
                ))}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
