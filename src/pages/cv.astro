---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    Ph.D. student in Computer Science at the Polytechnic University of Bari, working on scalable
    generative models for high-dimensional, low-sample domains. My research combines flow- and
    diffusion-based synthesis for 3D data augmentation in structured multi-scale representations
    with multimodal semantic representations from large vision–language models, with a focus on
    XAI-driven model interpretability, systematic evaluation frameworks, and reproducible
    experimental design. A central thread of my work is the design and validation of 3D generative
    models for full-resolution brain MRI, integrating multi-site preprocessing workflows and
    anatomy-aware evaluation as core components of the research pipeline.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Current Position</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Ph.D. Student — Generative Deep Models"
      subtitle="Nov 2023 – Nov 2026 • Polytechnic University of Bari"
    >
      <ul class="list-disc mx-6">
        <li>Scalable generative models for high-dimensional, low-sample domains, combining flow- and
          diffusion-based synthesis for 3D data augmentation with multimodal semantic representations
          from large vision–language models.</li>
        <li>XAI-driven interpretability, systematic evaluation frameworks, and reproducible
          experimental design.</li>
        <li>Design and validation of 3D generative models for full-resolution brain MRI, with
          multi-site preprocessing and anatomy-aware evaluation.</li>
      </ul>
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="M.S. in Computer Science Engineering — Information Systems"
      subtitle="2023 • Polytechnic University of Bari"
    >
      <span class="font-semibold">Thesis:</span>
      An autoregressive transformer-based model that synthesises complete 3D environments from
      a room type, desired styles, and a textual description of the furnishings.
    </TimeLineElement>
    <TimeLineElement
      title="B.S. in Computer Science and Automation Engineering"
      subtitle="2019 • Polytechnic University of Bari"
    >
      <span class="font-semibold">Thesis:</span>
      State-of-the-art study of methodologies for the effective and scalable design of complex
      information systems.
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Research Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Research Fellow — SisInfLab"
      subtitle="May 2023 – Nov 2023 • Polytechnic University of Bari"
    >
      Analysis of multispectral satellite imagery with deep learning and time-series methods to
      assess the impact of <em>Xylella fastidiosa</em> on Mediterranean crops and inform
      sustainable agricultural strategies.
    </TimeLineElement>
    <TimeLineElement
      title="Research Internship — SisInfLab"
      subtitle="Sep 2022 – Apr 2023 • Polytechnic University of Bari"
    >
      Proof-of-concept virtual reality system for furniture showrooms based on generative AI,
      built to validate commercial potential with companies in the sector.
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Research Projects</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="MISTRAL — European Research Project"
      subtitle="2024 • Health Impact Assessment toolkit"
    >
      Digital toolkit for Health Impact Assessment using AI to predict the effect of environmental
      and socio-economic factors on disability and quality of life. Federated-learning architecture,
      validated on steel-plant pollution exposure scenarios in Taranto (Italy), Rybnik (Poland),
      and Flanders (Belgium).
    </TimeLineElement>
    <TimeLineElement
      title="OMIBREED — National Research Project"
      subtitle="2023, 2024, 2026"
    >
      Full-stack platform for partner data intake and analysis of <em>Xylella fastidiosa</em>-affected
      olive trees, streamlining omics data workflows and supporting deep-learning model training.
    </TimeLineElement>
    <TimeLineElement
      title="Industry Research — Digital Tech Company"
      subtitle="2024"
    >
      Federated-learning proof-of-concept for distributed collaborative training of predictive
      models while preserving the confidentiality of sensitive patient data.
    </TimeLineElement>
    <TimeLineElement
      title="Industry Research — Furnishing Company"
      subtitle="2023"
    >
      Generative-AI proof-of-concept for furniture showrooms, integrated with a virtual reality
      system to advance practical application in the sector.
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Teaching &amp; Service</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Teaching Assistant — Polytechnic University of Bari"
      subtitle="2024, 2025, 2026"
    >
      Courses: Deep Learning; Foundations of Machine Learning.
    </TimeLineElement>
    <TimeLineElement
      title="Lecturer"
      subtitle="2024, 2025"
    >
      <ul class="list-disc mx-6">
        <li><em>Artificial Intelligence: From Basics to Generative AI</em> — ITS Academy Apulia
          Digital Maker.</li>
        <li><em>Fundamentals of Network and System Security</em> — Spegea Business School.</li>
      </ul>
    </TimeLineElement>
    <TimeLineElement
      title="Reviewer"
      subtitle="Selected venues"
    >
      Data Mining and Knowledge Discovery; Nature Scientific Reports; ECIR'25; UMAP'25; XAI'25;
      ECAI'25; AAAI'25; ICLR'25; CVPR'26; MICCAI'26.
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Conferences &amp; Workshops Attended</div>
  </div>

  <ul class="list-disc mx-6 mb-10">
    <li><span class="font-semibold">2025:</span> CIKM; XAI.</li>
    <li><span class="font-semibold">2024:</span> RecSys; RecSys Summer School; XAI; GeMSS — Generative Modeling Summer School.</li>
    <li><span class="font-semibold">2023:</span> Learning on Graphs Conference.</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Technical Skills</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-1">
    <li><span class="font-semibold">Neuroimaging:</span> FreeSurfer, FastSurfer, FSL/FLIRT, ANTsPy.</li>
    <li><span class="font-semibold">Languages &amp; tools:</span> Python, C/C++, MATLAB, JavaScript, Bash, Linux, Git.</li>
    <li><span class="font-semibold">ML frameworks:</span> PyTorch, scikit-learn, TensorFlow.</li>
    <li><span class="font-semibold">Data:</span> PySpark, Hive, Hadoop, SQL, MongoDB.</li>
    <li><span class="font-semibold">Web:</span> HTML, CSS, Streamlit, Gradio.</li>
    <li><span class="font-semibold">Other:</span> Docker, LaTeX, Slurm, Colab.</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Languages</div>
  </div>

  <ul class="list-disc mx-6 mb-10">
    <li><span class="font-semibold">Italian:</span> Native.</li>
    <li><span class="font-semibold">English:</span> Fluent (TOEIC).</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10">
    <li>Italian Habilitation for the Profession of Information Engineer (Section A) — 2023.</li>
    <li>Deep Learning with PyTorch for Medical Image Analysis — Udemy, 2023.</li>
  </ul>
</BaseLayout>
